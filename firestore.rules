rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function sameGym() {
      return signedIn() && resource.data.gymId == userDoc().data.gymId;
    }

    function incomingSameGym() {
      return signedIn() && request.resource.data.gymId == userDoc().data.gymId;
    }

    function owner() {
      return signedIn() && userDoc().data.role == "owner";
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || owner());
      allow create: if signedIn() && request.auth.uid == userId;
      allow update, delete: if owner();
    }

    match /gym_settings/{docId} {
      allow read: if sameGym();
      allow create, update: if owner() && incomingSameGym();
      allow delete: if false;
    }

    match /{collection}/{docId} {
      allow read: if sameGym();
      allow create: if incomingSameGym();
      allow update: if sameGym() && incomingSameGym();
      allow delete: if owner() && sameGym();
    }
  }
}
